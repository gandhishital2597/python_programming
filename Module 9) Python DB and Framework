from django.shortcuts import redirect
from django.urls import reverse

class BlockExpiredOTPAccessMiddleware:

    def __init__(self, get_response):
        self.get_response = get_response

    def __call__(self, request):
        # Get current path
        path = request.path

        # Define OTP verification URL
        otp_verify_url = reverse('verify_otp')

        # Check if user is accessing OTP verification page
        if path == otp_verify_url:
            otp = request.session.get('otp')

            # If OTP is missing (expired or not generated)
            if not otp:
                return redirect('forgot_password')

        response = self.get_response(request)
