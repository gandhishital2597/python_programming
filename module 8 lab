Practical Examples: 20) Write a Python program to show method overriding.
class Animal:
    def sound(self):
        print("Animal makes a sound")

class Dog(Animal):
    def sound(self):   # overriding parent method
        print("Dog barks")

class Cat(Animal):
    def sound(self):   # overriding parent method
        print("Cat meows")

# Create objects
a = Animal()
d = Dog()
c = Cat()

# Call methods
a.sound()   # Parent class method
d.sound()   # Dog class method
c.sound()   # Cat class method

